AWS_REGION=us-east-1
DEMO_USER=ubuntu
# Haiku 4.5 (이전 기본 · 빠르고 저렴 — 나중에 쓰려면 주석 해제):
# DBQUERY_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
DBQUERY_MODEL_ID=global.anthropic.claude-sonnet-4-6
DBQUERY_TEMPERATURE=0.1
DBQUERY_MAX_TOKENS=4096
# Haiku 4.5 (이전 기본 — 나중에 쓰려면 주석 해제):
# ANALYZE_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
ANALYZE_MODEL_ID=global.anthropic.claude-sonnet-4-6
ANALYZE_TEMPERATURE=0.1
ANALYZE_MAX_TOKENS=2048
# META_BACKEND: mock | sqlite  (redis는 배포 단계)
META_BACKEND=mock
REDIS_URL=redis://localhost:6379/0
LARGE_TABLE_THRESHOLD=1000000
# TOOLS_SOURCE: inprocess | gateway
# inprocess(기본) — 오프라인 in-process @tool 에이전트 (Cognito/Gateway 불필요)
# gateway       — Cognito-보안 Gateway MCP 도구 에이전트 (아래 변수 필요)
TOOLS_SOURCE=inprocess
# Cognito + Gateway 변수 (auto-filled by infra/cognito-gateway/deploy.sh)
COGNITO_USER_POOL_ID=
COGNITO_DOMAIN=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_GATEWAY_SCOPE=
GATEWAY_URL=
GATEWAY_ID=
OAUTH_PROVIDER_NAME=
